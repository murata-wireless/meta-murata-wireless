+static int wpa_driver_nl80211_enable_ssid_prot(void *priv, u8 enable)
+{
+	struct i802_bss *bss = priv;
+	struct wpa_driver_nl80211_data *drv = bss->drv;
+	struct nl_msg *msg;
+	struct nlattr *params;
+	int ret = -1;
+	wpa_printf(MSG_DEBUG, "nl80211: IFX enable ssid protection FILS=%d", enable);
+
+	if (!drv->ifx_ssid_prot)
+		return ret;
+
+	if (!(msg = nl80211_drv_msg(drv, 0, NL80211_CMD_VENDOR)) ||
+	    nla_put_u32(msg, NL80211_ATTR_VENDOR_ID, OUI_IFX) ||
+	    nla_put_u32(msg, NL80211_ATTR_VENDOR_SUBCMD,
+			IFX_VENDOR_SCMD_SSID_PROT) ||
+	    !(params = nla_nest_start(msg, NL80211_ATTR_VENDOR_DATA)) ||
+	    nla_put_u8(msg, IFX_VENDOR_ATTR_SSID_PROT_ENABLE,
+		       enable)) {
+		goto fail;
+	}
+	nla_nest_end(msg, params);
+
+	ret = send_and_recv_cmd(drv, msg);
+	if (ret)
+		wpa_printf(MSG_ERROR, "nl80211: SSID PROT: Failed to invoke driver %s",
+			strerror(-ret));
+
+	return ret;
+fail:
+	nl80211_nlmsg_clear(msg);
+	nlmsg_free(msg);
+	return ret;
+
+}
