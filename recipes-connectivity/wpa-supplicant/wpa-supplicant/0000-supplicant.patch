+			return pos - buffer;
+		pos += ret;
+
+	} else {
+		ret = os_snprintf(pos, end - pos, "wpa_auth=NONE\n");
+		if (os_snprintf_error(end - pos, ret))
+			return pos - buffer;
+		pos += ret;
+	}
+
+	return pos - buffer;
+}
