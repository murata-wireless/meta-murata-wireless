From cd85c5776767d531d1d1578966563cdf061e5d10 Mon Sep 17 00:00:00 2001
From: Romit Chatterjee <romit.chatterjee@murata.com>
Date: Fri, 8 Aug 2025 08:16:07 -0500
Subject: [PATCH] Upstream-Status: Inappropriate [board/product-specific
 changes]

---
 net/wireless/Kconfig | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/net/wireless/Kconfig b/net/wireless/Kconfig
index 10345388ad13..596f5e76071e 100644
--- a/net/wireless/Kconfig
+++ b/net/wireless/Kconfig
@@ -91,7 +91,7 @@ config CFG80211_CERTIFICATION_ONUS
 
 config CFG80211_REQUIRE_SIGNED_REGDB
 	bool "require regdb signature" if CFG80211_CERTIFICATION_ONUS
-	default y
+	default n
 	select SYSTEM_DATA_VERIFICATION
 	help
 	  Require that in addition to the "regulatory.db" file a
@@ -101,7 +101,7 @@ config CFG80211_REQUIRE_SIGNED_REGDB
 
 config CFG80211_USE_KERNEL_REGDB_KEYS
 	bool "allow regdb keys shipped with the kernel" if CFG80211_CERTIFICATION_ONUS
-	default y
+	default n
 	depends on CFG80211_REQUIRE_SIGNED_REGDB
 	help
 	  Allow the regulatory database to be signed by one of the keys for
-- 
